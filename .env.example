# WebRAG System Environment Variables Example

# API Keys
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# Embedding Configuration
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5

# Vector Database (ChromaDB)
CHROMA_DB_DIR=./data/chromadb

# Relational Database (SQLite)
DATABASE_URL=sqlite:///./data/webrag.db

# Crawler Settings
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=20
CRAWL_USER_AGENT="WebRAG-Bot/1.0 (+http://localhost)"

# Scheduler Settings
REFRESH_INTERVAL_HOURS=6
